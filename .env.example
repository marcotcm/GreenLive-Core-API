# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================================
# Formato: postgresql+asyncpg://<usuario>:<password>@<host>/<nombre_base_datos>
DATABASE_URL=postgresql+asyncpg://postgres:tu_password_aqui@localhost/Green_live

# ==========================================
# SEGURIDAD Y AUTENTICACIÓN (JWT)
# ==========================================
# Clave secreta para firmar los tokens (Usa un string largo y aleatorio en producción)
SECRET_KEY=escribe_tu_clave_secreta_aqui

# Algoritmo de encriptación para JWT (HS256 es el estándar recomendado)
ALGORITHM=HS256

# Tiempo de vida del token de acceso en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# CONFIGURACIÓN DE CORS
# ==========================================
# Lista de URLs permitidas para conectarse a esta API (ej. ["http://localhost:5173"])
BACKEND_CORS_ORIGINS=["*"]